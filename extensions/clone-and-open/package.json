{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "clone-and-open",
  "title": "Clone and Open",
  "description": "Clone a remote git repository and open it in your editor",
  "icon": "icon.png",
  "author": "josephshambrook",
  "categories": [
    "Developer Tools"
  ],
  "license": "MIT",
  "commands": [
    {
      "name": "index",
      "title": "Clone Repository",
      "description": "Clone a remote git repo into your dev folder and open it in your editor",
      "mode": "view"
    }
  ],
  "preferences": [
    {
      "name": "devFolder",
      "title": "Dev Folder",
      "description": "Directory where repositories will be cloned into",
      "type": "textfield",
      "default": "~/dev",
      "required": false
    },
    {
      "name": "editor",
      "title": "Editor",
      "description": "Editor to open the cloned repo in",
      "type": "dropdown",
      "default": "code",
      "required": false,
      "data": [
        {
          "title": "VS Code",
          "value": "code"
        },
        {
          "title": "Cursor",
          "value": "cursor"
        },
        {
          "title": "Zed",
          "value": "zed"
        },
        {
          "title": "WebStorm",
          "value": "webstorm"
        },
        {
          "title": "Fleet",
          "value": "fleet"
        }
      ]
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.93.2"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^1.0.11",
    "@types/node": "^22.19.17",
    "@types/react": "^19.0.10",
    "eslint": "^8.57.0",
    "prettier": "^3.3.3",
    "typescript": "^5.4.5"
  },
  "overrides": {
    "minimatch": "^9.0.9"
  },
  "scripts": {
    "build": "ray build",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "publish": "npx @raycast/api@latest publish"
  }
}
